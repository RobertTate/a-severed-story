---
// The shared handbook header: Lumon globe + wordmark on the left, the current
// chapter name and the Chapters dropdown grouped on the right.
//
// The `.nav-right` grouping (page name beside the dropdown) used to be assembled
// at runtime by lumon.js' pageNameInNav(); it is now authored directly here.
import { chapters } from "../data/chapters";

interface Props {
  /** Title of the page currently being viewed, shown beside the dropdown. */
  pageTitle?: string;
}

const { pageTitle } = Astro.props;

// The slug of the page currently being viewed, used to flag the matching
// entry in the Chapters dropdown. Strip any trailing slash so "/preamble/"
// and "/preamble" both match.
const currentSlug = Astro.url.pathname.replace(/^\/|\/$/g, "");
---

<nav transition:animate="none">
  <a href="/">
    <img src="/assets/lumon-globe-black.png" alt="Lumon Industries" />
    <span>Severed Story</span>
  </a>
  <div class="nav-right">
    {pageTitle && <span class="nav-page">{pageTitle}</span>}
    <details>
      <summary>Chapters</summary>
      <ul>
        {
          chapters.map((c) => (
            <li>
              <a
                href={`/${c.slug}`}
                aria-current={c.slug === currentSlug ? "page" : undefined}
              >
                {c.navTitle ?? c.title}
              </a>
            </li>
          ))
        }
      </ul>
    </details>
  </div>
</nav>
