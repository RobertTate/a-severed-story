---
// The cover — a bespoke Publisher title card. Stands apart from ChapterLayout:
// it has no nav and its own full-bleed layout. It still pulls in lumon.css for
// the shared design tokens (--lumon-blue, --paper, fonts, …) that its styles use.
import { ClientRouter } from "astro:transitions";
import "../styles/lumon.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>A Severed Story &middot; Lumon Industries</title>
    <ClientRouter />
  </head>
  <body>
    <main class="cv">
      <div class="cv__holes" aria-hidden="true"><i></i><i></i><i></i></div>

      <header class="cv__head">
        <div class="cv__brand">
          <img src="/assets/lumon-globe-white.png" alt="Lumon Industries" />
          <span>Lumon Industries Presents</span>
        </div>
        <div class="cv__stamp">Produced in Kier, PE<br />Edition - Alpha</div>
      </header>

      <section class="cv__main">
        <h1 class="cv__title">A Severed Story</h1>
        <div class="cv__rule" aria-hidden="true"></div>
        <p class="cv__sub">
          A tabletop roleplaying game exploring the lives of Lumon's happiest
          team members.
        </p>
      </section>

      <footer class="cv__foot">
        <div class="cv__property">
          <div class="line1">Property of Lumon Industries</div>
          <div class="line2">
            A passion project by Robert Tate. Not intended for Commercial Use.
            Praise Kier.
          </div>
        </div>
        <a class="cv__cta" href="/table-of-contents"
          ><span>Begin Orientation</span><i
            class="cv__cta-line"
            aria-hidden="true"></i></a
        >
      </footer>
    </main>
  </body>
</html>

<style is:global>
  /* ========================================================================
     COVER — reinvented from scratch against the Lumon design system.
     The official Publisher artifact: a glossy corporate-blue title card,
     a page pulled from a Lumon binder — with the saboteur's first
     intrusion already taped to the corner.
     ======================================================================== */
  html,
  body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    background: var(--lumon-blue-deep);
  }

  .cv {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    box-sizing: border-box;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: 40px clamp(28px, 6vw, 96px);
    padding-left: clamp(56px, 8vw, 128px);
    /* room for the binder margin */
    background: var(--lumon-blue);
    color: var(--paper);
    font-family: var(--font-text);
  }

  /* flooded-blue title-card duotone: soft overhead light, darker corners */
  .cv::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(
        120% 80% at 30% -10%,
        rgba(255, 255, 255, 0.16),
        rgba(255, 255, 255, 0) 46%
      ),
      radial-gradient(
        120% 120% at 100% 120%,
        rgba(11, 32, 64, 0.55),
        rgba(11, 32, 64, 0) 50%
      );
  }

  /* engraved keyline, like the border printed on a real Lumon page */
  .cv::after {
    content: "";
    position: absolute;
    inset: 18px;
    pointer-events: none;
    border: 1px solid rgba(244, 243, 238, 0.16);
  }

  .cv > * {
    position: relative;
    z-index: 2;
  }

  /* ---- the punched binder margin ---- */
  .cv__holes {
    position: absolute;
    z-index: 3;
    left: clamp(20px, 3.4vw, 46px);
    top: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(60px, 13vh, 120px);
    pointer-events: none;
  }

  .cv__holes i {
    width: clamp(14px, 1.5vw, 20px);
    min-width: 21px;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--lumon-blue-deep);
    box-shadow:
      inset 0 2px 3px rgba(0, 0, 0, 0.55),
      inset 0 -1px 0 rgba(255, 255, 255, 0.1);
  }

  /* ---- header ---- */
  .cv__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .cv__brand {
    display: flex;
    align-items: center;
    gap: 13px;
  }

  .cv__brand img {
    height: 52px;
    width: auto;
    display: block;
  }

  .cv__brand span {
    font-weight: var(--w-bold);
    font-size: 12px;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--paper);
  }

  .cv__stamp {
    font-weight: var(--w-bold);
    font-size: 11px;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: rgba(244, 243, 238, 0.62);
    text-align: right;
  }

  /* ---- title block (editorial, hard-left) ---- */
  .cv__main {
    align-self: center;
    max-width: none;
    padding: 24px 0;
  }

  .cv__title {
    font-family: var(--font-display-pub);
    font-weight: var(--w-regular);
    font-size: clamp(30px, min(7vw, 11vh), 72px);
    line-height: 1.02;
    letter-spacing: 0;
    color: var(--paper);
    margin: 0;
    word-break: keep-all;
    overflow-wrap: normal;
  }

  .cv__title b {
    font-weight: var(--w-regular);
    display: block;
  }

  .cv__rule {
    height: 10px;
    width: 120px;
    margin: clamp(26px, 4vh, 40px) 0 clamp(22px, 3vh, 30px);
    background: repeating-linear-gradient(
      to bottom,
      var(--paper) 0 1px,
      transparent 1px 3px
    );
  }

  .cv__sub {
    font-family: var(--font-display);
    font-weight: var(--w-light);
    font-style: italic;
    font-size: clamp(17px, 1.7vw, 22px);
    line-height: 1.4;
    color: rgba(244, 243, 238, 0.92);
    margin: 0;
    max-width: 26ch;
  }

  /* ---- footer ---- */
  .cv__foot {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .cv__property {
    max-width: 42ch;
  }

  .cv__property .line1 {
    font-weight: var(--w-bold);
    font-size: 11px;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: rgba(244, 243, 238, 0.62);
    margin-bottom: 6px;
  }

  .cv__property .line2 {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--w-light);
    font-size: 14px;
    color: rgba(244, 243, 238, 0.62);
  }

  .cv__cta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 15px 30px;
    background: var(--paper);
    color: var(--ink);
    text-decoration: none;
    font-weight: var(--w-bold);
    font-size: 12px;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    white-space: nowrap;
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.35);
    transition:
      transform 200ms ease,
      background-color 200ms ease;
  }

  /* trailing arrow: a shaft (the line) + a chevron head pushed along by it */
  .cv__cta-line {
    width: 26px;
    height: 2px;
    background: var(--ink);
    transition: width 200ms ease;
  }

  .cv__cta::after {
    content: "";
    width: 8px;
    height: 8px;
    margin-left: -23px;
    border-top: 2.5px solid var(--ink);
    border-right: 2.5px solid var(--ink);
    transform: rotate(45deg);
  }

  .cv__cta:hover {
    background: var(--pure-white);
  }

  .cv__cta:hover .cv__cta-line {
    width: 38px;
  }

  /* ---- the first intrusion: a C.C. ballpoint scrap, taped to the corner ---- */
  .cv__scrap {
    position: absolute;
    z-index: 4;
    right: clamp(24px, 5vw, 88px);
    top: clamp(150px, 34vh, 320px);
    width: clamp(200px, 20vw, 264px);
    padding: 22px 22px 18px;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.015), rgba(0, 0, 0, 0.06)),
      var(--manila);
    color: var(--cc-ink);
    transform: rotate(-3.5deg);
    box-shadow:
      0 2px 3px rgba(0, 0, 0, 0.18),
      0 26px 44px -22px rgba(0, 0, 0, 0.7);
    transition:
      transform 240ms cubic-bezier(0.2, 0.7, 0.3, 1),
      box-shadow 240ms ease;
  }

  .cv__scrap:hover {
    transform: rotate(-1.4deg) translateY(-4px);
    box-shadow:
      0 3px 5px rgba(0, 0, 0, 0.2),
      0 34px 56px -24px rgba(0, 0, 0, 0.75);
  }

  .cv__scrap::before,
  .cv__scrap::after {
    content: "";
    position: absolute;
    top: -13px;
    width: 86px;
    height: 27px;
    background: var(--tape);
    border-left: 1px solid rgba(255, 255, 255, 0.4);
    border-right: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.14);
  }

  .cv__scrap::before {
    left: 18px;
    transform: rotate(-5deg);
  }

  .cv__scrap::after {
    right: 18px;
    transform: rotate(4deg);
  }

  .cv__scrap p {
    font-family: var(--hand);
    font-size: 19px;
    line-height: 1.42;
    margin: 0 0 0.5em;
    color: var(--cc-ink);
  }

  .cv__scrap .sig {
    margin: 0;
    font-size: 20px;
    font-weight: 700;
  }

  @media (max-width: 720px) {
    .cv {
      grid-template-rows: auto 1fr auto;
      padding: 28px 22px 28px 52px;
      gap: 24px;
    }

    .cv::after {
      inset: 11px;
    }

    .cv__holes {
      display: none;
    }

    .cv__brand span {
      display: none;
    }

    .cv__title {
      font-size: clamp(30px, 11vw, 52px);
    }

    .cv__scrap {
      position: static;
      width: auto;
      max-width: 300px;
      margin: 14px 0 0;
      transform: rotate(-2deg);
    }

    .cv__foot {
      gap: 18px;
    }
  }

  @media (max-height: 560px) {
    .cv__scrap {
      display: none;
    }

    .cv__main {
      padding: 8px 0;
    }
  }
</style>
