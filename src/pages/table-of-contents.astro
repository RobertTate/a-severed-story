---
import ChapterLayout from "../layouts/ChapterLayout.astro";
import BinderHoles from "../components/BinderHoles.astro";
import { chapters } from "../data/chapters";

const tocEntries = chapters.filter((c) => !c.hideFromToc);
---

<ChapterLayout title="Table of Contents" headVoice="publisher">
  <div data-voice="publisher" class="toc">
    <BinderHoles />
    <blockquote>
      {
        tocEntries.map((c) => (
          <Fragment>
            <h3>
              <a href={`/${c.slug}`}>{c.title}</a>
            </h3>
            <p>
              <em>
                <sup>{c.blurb}</sup>
              </em>
            </p>
          </Fragment>
        ))
      }
    </blockquote>
  </div>
</ChapterLayout>

<style is:global>
  /* The Table of Contents page speaks in the PUBLISHER voice (the blue
     title-card identity). Below: TOC-specific tuning so the chapter index
     reads as a clean list on the blue field rather than a heavy rules panel. */
  [data-voice="publisher"].toc > h2::before {
    content: none;
  }

  /* no § counter on the contents title */
  [data-voice="publisher"].toc > blockquote {
    margin: var(--space-4) 0 var(--space-7);
    padding: 0;
    background: none;
    border: none;
    border-left: none;
  }

  [data-voice="publisher"].toc > blockquote h3 {
    margin: 0;
    padding: var(--space-5) 0 4px;
    border-top: 1px solid rgba(244, 243, 238, 0.22);
    font-family: var(--font-display);
    font-weight: var(--w-light);
    font-size: clamp(21px, 2.4vw, 29px);
    letter-spacing: -0.01em;
    color: var(--paper);
  }

  [data-voice="publisher"].toc > blockquote h3:first-child {
    border-top: none;
  }

  [data-voice="publisher"].toc > blockquote h3 a {
    color: var(--paper);
    font-weight: var(--w-light);
    text-decoration: none;
    transition: opacity 140ms ease;
  }

  [data-voice="publisher"].toc > blockquote h3 a:hover {
    opacity: 0.58;
  }

  [data-voice="publisher"].toc > blockquote > p {
    margin: 0 0 var(--space-4);
  }

  [data-voice="publisher"].toc > blockquote sup {
    font-size: 14px;
    font-style: italic;
    letter-spacing: 0;
    color: rgba(244, 243, 238, 0.64);
  }
</style>
